      "source": [
        "# Agregamos columna de 1s para el bias\n",
        "X_design = np.column_stack([np.ones(n), X])          # shape (n, 2)\n",
        "theta = np.linalg.inv(X_design.T @ X_design) @ X_design.T @ y\n",
        "print(f\"θ = [b, w] = {theta}\")"
