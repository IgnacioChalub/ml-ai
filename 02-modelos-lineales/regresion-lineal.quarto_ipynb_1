    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "rng = np.random.default_rng(42)\n",
        "n = 40\n",
        "X = rng.uniform(-5, 5, n)\n",
        "true_w, true_b = 2.1, 1.5\n",
        "y = true_w * X + true_b + rng.normal(0, 1.2, n)\n",
        "\n",
        "# Ecuaciones normales forma simple\n",
        "x_mean, y_mean = X.mean(), y.mean()\n",
        "w = np.sum((X - x_mean) * (y - y_mean)) / np.sum((X - x_mean) ** 2)\n",
        "b = y_mean - w * x_mean\n",
        "\n",
        "mse = np.mean((y - (w * X + b)) ** 2)\n",
        "print(f\"w = {w:.4f}  (verdadero: {true_w})\")\n",
        "print(f\"b = {b:.4f}  (verdadero: {true_b})\")\n",
        "print(f\"MSE = {mse:.4f}\")"
      ],
